#include<iostream>
using namespace std;

int find_maximum(int * arr,int length)
{
/*write the code to find the maximum in an array
only return the maximum value. Both array and size of array is given */
    int max=-1;
    for(int i=0; i<length; i++){
        if(max<=arr[i]){
            max=arr[i];
        }
        else{
            max=max;
        }

    }
    return max;
 
 /* Dont change anything below. If changed click on reset. */

}

int main()
{
    int n;
    cin>>n;
    int arr[n];
    for(int i=0;i<n;i++)
    {
        cin>>arr[i];
    }
    int max = find_maximum(arr,n);
    cout<<max<<endl;
    return 0;
}
