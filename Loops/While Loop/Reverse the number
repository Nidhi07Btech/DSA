#include<iostream>
using namespace std;

int reverse();
/*Function to return the reverse of a number  */

int reverse(int n)
{
    /* Function to return the reverse of a number n */
    int num=0;

    while(n != 0){
      int rem = n%10;
      num= num*10 + rem;
       n/=10;
    }
    return num;
 
